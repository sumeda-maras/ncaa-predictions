      "source": [
        "df_season_results = pd.concat([\n",
        "    pd.read_csv(DATA_PATH + \"MRegularSeasonCompactResults.csv\"),\n",
        "    pd.read_csv(DATA_PATH + \"WRegularSeasonCompactResults.csv\"),\n",
        "], ignore_index=True)\n",
        "\n",
        "df_season_results.drop(['NumOT', 'WLoc'], axis=1, inplace=True)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "3QE40jvPF2ZD"
      },
      "outputs": [],
      "source": [
        "df_season_results['ScoreGap'] = df_season_results['WScore'] - df_season_results['LScore']"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "0llaWW_DF5UB"
      },
      "outputs": [],
      "source": [
        "num_win = df_season_results.groupby(['Season', 'WTeamID']).count()\n",
        "num_win = num_win.reset_index()[['Season', 'WTeamID', 'DayNum']].rename(columns={\"DayNum\": \"NumWins\", \"WTeamID\": \"TeamID\"})"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "I64oF8NtF7MQ"
      },
      "outputs": [],
      "source": [
        "num_loss = df_season_results.groupby(['Season', 'LTeamID']).count()\n",
        "num_loss = num_loss.reset_index()[['Season', 'LTeamID', 'DayNum']].rename(columns={\"DayNum\": \"NumLosses\", \"LTeamID\": \"TeamID\"})"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "1Mg2dFnyF9EQ"
      },
      "outputs": [],
      "source": [
        "gap_win = df_season_results.groupby(['Season', 'WTeamID']).mean().reset_index()\n",
        "gap_win = gap_win[['Season', 'WTeamID', 'ScoreGap']].rename(columns={\"ScoreGap\": \"GapWins\", \"WTeamID\": \"TeamID\"})"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "PlArm2oLF-fl"
      },
      "outputs": [],
      "source": [
        "gap_loss = df_season_results.groupby(['Season', 'LTeamID']).mean().reset_index()\n",
        "gap_loss = gap_loss[['Season', 'LTeamID', 'ScoreGap']].rename(columns={\"ScoreGap\": \"GapLosses\", \"LTeamID\": \"TeamID\"})"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "rnquuFs2GAXO"
      },
      "outputs": [],
      "source": [
        "# Merge all dfs together\n",
        "df_features_season_w = df_season_results.groupby(['Season', 'WTeamID']).count().reset_index()[['Season', 'WTeamID']].rename(columns={\"WTeamID\": \"TeamID\"})\n",
        "df_features_season_l = df_season_results.groupby(['Season', 'LTeamID']).count().reset_index()[['Season', 'LTeamID']].rename(columns={\"LTeamID\": \"TeamID\"})\n",
        "\n",
        "df_features_season = pd.concat([df_features_season_w, df_features_season_l], axis=0).drop_duplicates().sort_values(['Season', 'TeamID']).reset_index(drop=True)\n",
        "\n",
        "df_features_season = df_features_season.merge(num_win, on=['Season', 'TeamID'], how='left')\n",
        "df_features_season = df_features_season.merge(num_loss, on=['Season', 'TeamID'], how='left')\n",
        "df_features_season = df_features_season.merge(gap_win, on=['Season', 'TeamID'], how='left')\n",
        "df_features_season = df_features_season.merge(gap_loss, on=['Season', 'TeamID'], how='left')\n",
        "\n",
        "# Fil NAs with 0's\n",
        "df_features_season.fillna(0, inplace=True)"
      ]
    },
